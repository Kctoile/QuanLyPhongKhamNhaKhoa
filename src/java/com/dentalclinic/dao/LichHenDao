package com.dentalclinic.dao;

import com.dentalclinic.model.LichHen;
import com.dentalclinic.utils.DBConnection;
import java.sql.*;
import java.util.ArrayList;
import java.util.List;

public class LichHenDAO {

    public List<LichHen> getAllLichHenToday() {
        List<LichHen> list = new ArrayList<>();
        // Query kết hợp thông tin từ bảng NguoiDung và DichVu
        String sql = "SELECT lh.*, nd.HoTen, nd.SoDienThoai, dv.TenDV " +
                     "FROM LichHen lh " +
                     "JOIN NguoiDung nd ON lh.MaND = nd.MaND " +
                     "JOIN DichVu dv ON lh.MaDV = dv.MaDV " +
                     "WHERE CAST(lh.NgayHen AS DATE) = CAST(GETDATE() AS DATE) " +
                     "ORDER BY lh.NgayHen ASC";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ResultSet rs = ps.executeQuery();
            while (rs.next()) {
                LichHen lh = new LichHen();
                lh.setMaLH(rs.getInt("MaLH"));
                lh.setTenKhachHang(rs.getString("HoTen"));
                lh.setSoDienThoai(rs.getString("SoDienThoai"));
                lh.setTenDichVu(rs.getString("TenDV"));
                lh.setNgayHen(rs.getString("NgayHen"));
                lh.setTrangThai(rs.getString("TrangThai"));
                list.add(lh);
            }
        } catch (Exception e) { e.printStackTrace(); }
        return list;
    }

    public boolean updateStatus(int maLH, String status) {
        String sql = "UPDATE LichHen SET TrangThai = ? WHERE MaLH = ?";
        try (Connection conn = DBConnection.getConnection();
             PreparedStatement ps = conn.prepareStatement(sql)) {
            ps.setString(1, status);
            ps.setInt(2, maLH);
            return ps.executeUpdate() > 0;
        } catch (Exception e) { e.printStackTrace(); }
        return false;
    }
}
